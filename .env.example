# ── Binance Futures (DEMO = testnet 키, 실전 금지) ────────
BINANCE_DEMO_API_KEY=                # testnet.binancefuture.com 에서 발급
BINANCE_DEMO_SECRET_API_KEY=         # testnet secret
BINANCE_BASE_URL=https://testnet.binancefuture.com    # live (운영 시): https://fapi.binance.com
BINANCE_WS_URL=wss://fstream.binancefuture.com/ws     # live: wss://fstream.binance.com/ws
# (운영 전환 시 BINANCE_REAL_API_KEY 등을 별도 추가 — 본 이슈에서는 사용 안 함)

# ── KIS (한국투자증권, 사용자 네이밍 = HANTOO_*) ──────────
# 모의투자 (paper) — Phase 2 운영 (#105/#133) 에서 사용
HANTOO_FAKE_API_KEY=                # paper App Key
HANTOO_FAKE_SECRET_API_KEY=         # paper App Secret
HANTOO_FAKE_CREDIT_NUMBER=          # paper 모의계좌 번호 (포맷 ^[0-9]{8}-[0-9]{2}$, 예: 12345678-01)
                                    # 실거래 HANTOO_CREDIT_NUMBER 와 별도 — paper=True 시 우선 사용
HANTOO_HTS_ID=                      # HTS ID (smoke 미설정 시 'smoke' default, 실 운영 WS 구독엔 필요)
# 실전투자 (Phase 3 #107 까지 사용 금지)
HANTOO_REAL_API_KEY=
HANTOO_REAL_SECRET_API_KEY=
HANTOO_CREDIT_NUMBER=               # 실전 계좌번호 (포맷 8자리-2자리, paper 와 별도)

# ── 공통 토글 ───────────────────────────────────────────
ACTIVE_BROKER=kis                   # kis | binance_futures
BROKER_ROUTER_ENABLED=false         # P15: router 점진 롤아웃 flag

# ── KIS Phase 2 운영 설정 (#105 + #133) ───────────────
# 주의: KIS_APP_KEY / KIS_APP_SECRET / KIS_HTS_ID 는 실제 코드에서 사용하지 않는다 (#105 의 worker 가
# .env.example 에만 잘못 추가한 미사용 변수 — #133 에서 제거). 위쪽의 HANTOO_FAKE_* 가 표준.
KIS_PAPER=true                      # true=모의계좌, false=실거래 (default true — 실거래는 #107)
FX_USD_KRW_TTL_SEC=300              # USD/KRW 환율 캐시 TTL 초 (#105 Stage 1.2 fx_rate)
KIS_FILL_MISSING_HALT_THRESHOLD=1   # 체결 누락 halt 임계 (R2 트리거, #105 Architect note #5)

# ── #133 Phase 2 4주 운영 추가 (Telegram + max-orders) ───────────────
TELEGRAM_BOT_TOKEN=                 # @BotFather 발급 토큰 — 미설정 시 알림 skip (daemon 정상 작동)
TELEGRAM_CHAT_ID=                   # 본인 chat_id (https://api.telegram.org/bot{TOKEN}/getUpdates)
MAX_ORDERS=30                       # 첫 1주 보수 운영 — live_run.py --max-orders. 풀 운영 시 1000+ 또는 unset.
