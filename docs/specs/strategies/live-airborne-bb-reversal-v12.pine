//@version=5
// =============================================================================
// Airborne BB Reversal — Reverse-Engineered v1.2
// =============================================================================
// v1.1 (close 기준 + margin + body) 가 원본과 거의 일치하나, 둘 다 밴드라이딩
// 구간에서 손실 신호가 다수 발생 (강의 §1.4 의 경고 그대로 — 원본 인디
// 자체의 구조적 약점). v1.2 가 두 가지 밴드라이딩 회피 필터를 토글로 추가:
//
//   필터 A — 직전 N봉 BB 외부 카운트:
//     "직전 N봉 중 close 가 BB 외부에 있던 봉이 X개 초과면 진입 거부"
//     → 밴드라이딩 진행 중 진입 차단.
//     1y BTC 시뮬: 직전5/outside≤1 에서 손실률 -2.2pp + 적중률 +2.3pp.
//
//   필터 B — BB squeeze (변동성 압축):
//     "bandwidth = (upper-lower)/middle 이 직전 50봉의 25-percentile 이하"
//     → 밴드 좁은 횡보장만 진입 허용.
//     1y BTC 시뮬: 손실률 -4.6pp + 적중률 +10.6pp. 신호는 84% 감소.
//
// 둘 다 토글 가능. AND 조합 (둘 다 통과해야 발화) 또는 단독 사용.
//
// 사양: docs/specs/strategies/live-airborne-bb-reversal.md
// =============================================================================

indicator(
     title="Airborne BB Reversal (RE v1.2)",
     shorttitle="Airborne RE v1.2",
     overlay=true,
     max_lines_count=100,
     max_labels_count=200)

// ============== Inputs ==============
group_bb     = "Bollinger Bands"
bb_length    = input.int(20,   "BB Length",  minval=2,   group=group_bb)
bb_std       = input.float(2.0,"BB StdDev",  minval=0.1, step=0.1, group=group_bb)

group_logic  = "Trigger Logic"
retrace      = input.float(0.4,"Retrace Ratio", minval=0.05, maxval=0.95, step=0.05,
     tooltip="역공학 확정값 0.4", group=group_logic)

group_break  = "Breakout Filter (v1.1)"
min_margin   = input.float(0.001, "Min close margin (% of price)",
     minval=0.0, step=0.0001,
     tooltip="close 와 BB 사이 최소 거리. 0.001 = 0.1%.",
     group=group_break)
min_body     = input.float(0.005, "Min body (% of open)",
     minval=0.0, step=0.0001,
     tooltip="돌파봉의 body 최소 크기. 0.005 = 0.5%.",
     group=group_break)

group_filter  = "Band-riding Filters (v1.2 NEW)"
use_filter_a  = input.bool(true,  "[A] 직전 N봉 BB 외부 카운트",
     tooltip="밴드라이딩 회피. 직전 N봉 중 close 가 BB 밖에 있던 봉이 max 초과면 진입 거부.",
     group=group_filter)
filter_a_lookback = input.int(5, "  └ A: lookback (봉)", minval=2, maxval=50, group=group_filter)
filter_a_max_out  = input.int(1, "  └ A: max outside (≤이면 통과)",
     minval=0, maxval=10, group=group_filter)

use_filter_b      = input.bool(true,  "[B] BB squeeze (낮은 변동성만)",
     tooltip="bandwidth = (upper-lower)/middle 이 직전 window 의 percentile 이하일 때만 진입.",
     group=group_filter)
filter_b_window   = input.int(50, "  └ B: squeeze window", minval=10, maxval=200, group=group_filter)
filter_b_pctile   = input.float(0.25, "  └ B: percentile (0~1)",
     minval=0.05, maxval=1.0, step=0.05, group=group_filter)

group_ltf    = "Lower Timeframe BB"
ltf_tf       = input.timeframe("5", "LTF", group=group_ltf)

group_disp   = "Display"
show_bands   = input.bool(true, "HTF BB 표시", group=group_disp)
show_ltf     = input.bool(true, "LTF BB 표시", group=group_disp)
show_table   = input.bool(true, "상태 테이블 표시", group=group_disp)
show_setup   = input.bool(true, "대기 진입 마커 표시", group=group_disp)
table_pos    = input.string("top_right", "테이블 위치",
     options=["top_left","top_right","bottom_left","bottom_right"], group=group_disp)

// ============== HTF BB ==============
htf_basis = ta.sma(close, bb_length)
htf_dev   = ta.stdev(close, bb_length) * bb_std
htf_upper = htf_basis + htf_dev
htf_lower = htf_basis - htf_dev
bandwidth = htf_basis != 0 ? (htf_upper - htf_lower) / htf_basis : 0.0

// ============== LTF BB ==============
ltf_basis = request.security(syminfo.tickerid, ltf_tf,
     ta.sma(close, bb_length), lookahead=barmerge.lookahead_off)
ltf_dev_v = request.security(syminfo.tickerid, ltf_tf,
     ta.stdev(close, bb_length) * bb_std, lookahead=barmerge.lookahead_off)
ltf_upper = ltf_basis + ltf_dev_v
ltf_lower = ltf_basis - ltf_dev_v

// ============== Body + breakout thresholds (v1.1) ==============
body_pct = open == 0 ? 0.0 : math.abs(close - open) / open
upper_thr = htf_upper * (1 + min_margin)
lower_thr = htf_lower * (1 - min_margin)
upper_thr_prev = htf_upper[1] * (1 + min_margin)
lower_thr_prev = htf_lower[1] * (1 - min_margin)

upper_break = close > upper_thr and close[1] <= upper_thr_prev and body_pct >= min_body
lower_break = close < lower_thr and close[1] >= lower_thr_prev and body_pct >= min_body

// ============== Filter A: band-riding count ==============
count_above = math.sum(close > htf_upper ? 1 : 0, filter_a_lookback)
count_below = math.sum(close < htf_lower ? 1 : 0, filter_a_lookback)
filter_a_short_ok = not use_filter_a or count_above <= filter_a_max_out
filter_a_long_ok  = not use_filter_a or count_below <= filter_a_max_out

// ============== Filter B: BB squeeze (percentile) ==============
bw_threshold = ta.percentile_linear_interpolation(bandwidth, filter_b_window, filter_b_pctile * 100)
filter_b_ok = not use_filter_b or bandwidth <= bw_threshold

filter_short = filter_a_short_ok and filter_b_ok
filter_long  = filter_a_long_ok  and filter_b_ok

// ============== State Machine ==============
var int   state    = 0
var float base     = na
var float extreme  = na

if state == 0
    if upper_break and filter_short
        state   := 2
        base    := close
        extreme := high
    else if lower_break and filter_long
        state   := 1
        base    := close
        extreme := low

if state == 1 and not na(extreme)
    extreme := math.min(extreme, low)
if state == 2 and not na(extreme)
    extreme := math.max(extreme, high)

trigger = state == 1 ? extreme + retrace * (base - extreme) :
          state == 2 ? extreme - retrace * (extreme - base) : float(na)

long_fire  = false
short_fire = false

if barstate.isconfirmed
    if state == 1 and close >= trigger
        long_fire := true
        state := 0
        base := na
        extreme := na
    else if state == 2 and close <= trigger
        short_fire := true
        state := 0
        base := na
        extreme := na

new_long_setup  = state == 1 and (state[1] != 1)
new_short_setup = state == 2 and (state[1] != 2)

// ============== Plots ==============
plot(long_fire  ? 1 : 0, "에어본 롱",    color=color.lime,   display=display.data_window)
plot(short_fire ? 1 : 0, "에어본 숏",    color=color.red,    display=display.data_window)
plot(state == 1 ? 1 : 0, "롱 대기",      color=color.green,  display=display.data_window)
plot(state == 2 ? 1 : 0, "숏 대기",      color=color.maroon, display=display.data_window)
plot(filter_a_long_ok ? 1 : 0,  "필터A pass long",  color=color.teal,   display=display.data_window)
plot(filter_b_ok      ? 1 : 0,  "필터B pass",       color=color.orange, display=display.data_window)
plot(bandwidth, "BB width",   color=color.purple, display=display.data_window)

plot(show_bands ? htf_upper : na, "HTF BB 상단",
     color=color.new(color.blue, 40), linewidth=1)
plot(show_bands ? htf_basis : na, "HTF BB 중심(20이평)",
     color=color.new(color.orange, 30), linewidth=1)
plot(show_bands ? htf_lower : na, "HTF BB 하단",
     color=color.new(color.blue, 40), linewidth=1)
plot(show_ltf ? ltf_upper : na, "LTF BB 상단",
     color=color.new(color.aqua, 30), linewidth=1)
plot(show_ltf ? ltf_lower : na, "LTF BB 하단",
     color=color.new(color.aqua, 30), linewidth=1)

plotshape(long_fire,  title="에어본 롱 발화", style=shape.triangleup,
     location=location.belowbar, color=color.lime, size=size.normal, text="에어본 v1.2")
plotshape(short_fire, title="에어본 숏 발화", style=shape.triangledown,
     location=location.abovebar, color=color.red,  size=size.normal, text="에어본 v1.2")
plotshape(show_setup and new_long_setup,  title="롱 대기 진입",
     style=shape.circle, location=location.belowbar, color=color.green,
     size=size.tiny, text="대기")
plotshape(show_setup and new_short_setup, title="숏 대기 진입",
     style=shape.circle, location=location.abovebar, color=color.maroon,
     size=size.tiny, text="대기")

// ============== Status Table ==============
table_position(pos) =>
    switch pos
        "top_left"     => position.top_left
        "top_right"    => position.top_right
        "bottom_left"  => position.bottom_left
        "bottom_right" => position.bottom_right
        =>                position.top_right

var table status_tbl = na

if show_table
    if barstate.islast
        if na(status_tbl)
            status_tbl := table.new(table_position(table_pos), 2, 8,
                 frame_color=color.gray, frame_width=1,
                 border_color=color.gray, border_width=1)
        state_lbl = state == 1 ? "🟢 에어본 롱 대기" : state == 2 ? "🔴 에어본 숏 대기" : "⏸ 신호 없음"
        fa_long  = filter_a_long_ok  ? "✓" : "✗"
        fa_short = filter_a_short_ok ? "✓" : "✗"
        fb       = filter_b_ok       ? "✓" : "✗"
        bg_hdr   = color.new(color.black, 50)
        bg_row   = color.new(color.black, 75)
        tc       = color.white
        table.cell(status_tbl, 0, 0, "상태",        bgcolor=bg_hdr, text_color=tc)
        table.cell(status_tbl, 1, 0, state_lbl,     bgcolor=bg_hdr, text_color=tc)
        table.cell(status_tbl, 0, 1, "필터 A (롱/숏)", bgcolor=bg_row, text_color=tc)
        table.cell(status_tbl, 1, 1, fa_long + " / " + fa_short, bgcolor=bg_row, text_color=tc)
        table.cell(status_tbl, 0, 2, "필터 B (squeeze)", bgcolor=bg_row, text_color=tc)
        table.cell(status_tbl, 1, 2, fb + "  bw=" + str.tostring(bandwidth*100, "#.##") + "%",
             bgcolor=bg_row, text_color=tc)
        table.cell(status_tbl, 0, 3, "기준 시가",   bgcolor=bg_row, text_color=tc)
        table.cell(status_tbl, 1, 3, na(base)    ? "-" : str.tostring(base,    "#"),
             bgcolor=bg_row, text_color=tc)
        table.cell(status_tbl, 0, 4, "현재 극값",   bgcolor=bg_row, text_color=tc)
        table.cell(status_tbl, 1, 4, na(extreme) ? "-" : str.tostring(extreme, "#"),
             bgcolor=bg_row, text_color=tc)
        table.cell(status_tbl, 0, 5, "트리거가",    bgcolor=bg_row, text_color=tc)
        table.cell(status_tbl, 1, 5, na(trigger) ? "-" : str.tostring(trigger, "#"),
             bgcolor=bg_row, text_color=tc)
        table.cell(status_tbl, 0, 6, ltf_tf + "분 BB 상단", bgcolor=bg_row, text_color=tc)
        table.cell(status_tbl, 1, 6, str.tostring(ltf_upper, "#"), bgcolor=bg_row, text_color=tc)
        table.cell(status_tbl, 0, 7, ltf_tf + "분 BB 하단", bgcolor=bg_row, text_color=tc)
        table.cell(status_tbl, 1, 7, str.tostring(ltf_lower, "#"), bgcolor=bg_row, text_color=tc)

// ============== Alerts ==============
alertcondition(long_fire,  title="에어본 롱 v1.2 발화",
     message="Airborne v1.2 LONG fired @ {{ticker}} {{interval}}  close={{close}}")
alertcondition(short_fire, title="에어본 숏 v1.2 발화",
     message="Airborne v1.2 SHORT fired @ {{ticker}} {{interval}}  close={{close}}")
alertcondition(new_long_setup,  title="롱 대기 진입",
     message="Airborne v1.2 long setup armed @ {{ticker}} {{interval}}")
alertcondition(new_short_setup, title="숏 대기 진입",
     message="Airborne v1.2 short setup armed @ {{ticker}} {{interval}}")
